# ============================================
# Anis Linguistic Radar - إعدادات البيئة
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# ============================================

# ---------- الأمان الأساسي ----------
SECRET_KEY=هذا_مفتاح_التشفير_السري_يجب_تغييره
JWT_SECRET_KEY=مفتاح_آخر_لتوقيع_الرموز_يجب_أن_يكون_مختلفاً

# ---------- قاعدة البيانات ----------
# استخدم SQLite للتطوير أو PostgreSQL للإنتاج
DATABASE_URL=sqlite:///anis_radar.db
# مثال PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/anis_radar

# إعدادات تجمع الاتصالات (PostgreSQL)
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600

# ---------- Redis (تخزين مؤقت) ----------
# اتركها فارغة لتعطيل Redis واستخدام الذاكرة المحلية
REDIS_URL=redis://localhost:6379/0

# ---------- حدود المحتوى ----------
MAX_CONTENT_LENGTH=16777216    # 16 MB (افتراضي)
MIN_TEXT_LENGTH=10
MAX_TEXT_LENGTH=20000

# ---------- مسار الخط العربي ----------
# يجب أن يكون الملف موجوداً في المسار المحدد
FONT_PATH=static/fonts/Amiri-Regular.ttf

# ---------- تخزين الصور ----------
# مجلد تخزين الصور محلياً (يُنشأ تلقائياً)
UPLOAD_FOLDER=static/images

# استخدم S3 للرفع السحابي (ضع True لتفعيل)
USE_S3=False

# إعدادات S3 (تُفعَّل فقط إذا USE_S3=True)
S3_BUCKET=your-bucket-name
S3_KEY=your-access-key-id
S3_SECRET=your-secret-access-key
S3_REGION=us-east-1
S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com/

# ---------- حماية الطلبات ----------
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per day, 10 per minute

# ---------- JWT ----------
# مدة صلاحية التوكن بالثواني (ساعة = 3600)
JWT_ACCESS_TOKEN_EXPIRES=3600

# ---------- وضع التطوير ----------
FLASK_DEBUG=False
